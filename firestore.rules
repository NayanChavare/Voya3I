rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
         (request.auth.token.email == "nyogeshchavare23@gmail.com" && request.auth.token.email_verified == true));
    }

    function getInstitution() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.institution;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || (isAdmin() && resource.data.institution == getInstitution()));
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || (isAdmin() && resource.data.institution == getInstitution()));
      allow delete: if isAuthenticated() && (isAdmin() && resource.data.institution == getInstitution());
    }

    // Assessments
    match /assessments/{assessmentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || (isAdmin() && resource.data.institution == getInstitution()));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || (isAdmin() && resource.data.institution == getInstitution()));
    }

    // AI Interactions
    match /ai_interactions/{interactionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
  }
}
