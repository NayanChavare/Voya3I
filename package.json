{
  "name": "sdg-insight-framework",
  "private": true,
  "version": "1.0.4",
  "type": "module",
  "main": "dist/server.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "rm -rf dist && vite build && npm run build:server",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --outfile=dist/server.cjs --external:vite",
    "start": "NODE_ENV=production node dist/server.cjs",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google/genai": "^1.41.0",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.4",
    "express": "^5.2.1",
    "firebase": "^12.10.0",
    "lucide-react": "^0.564.0",
    "motion": "^12.34.3",
    "node-fetch": "^3.3.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "glob": "^13.0.6",
    "node-domexception": "^2.0.2"
  }
}
